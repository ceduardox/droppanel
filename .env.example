# Obligatorio (base de datos)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Recomendado (sesiones)
SESSION_SECRET=change_me_with_a_long_random_secret

# Necesario si usarás subida/lectura de imágenes/comprobantes
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# Opcional (solo si prefieres construir DATABASE_URL con estas variables)
PGDATABASE=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=

# Opcional
PORT=5000
REPL_ID=
